#include<bits/stdc++.h>
using namespace std;
int main(){
    int T;
    cin>>T;
    while(T--){
        int n;
        cin>>n;
        vector<int>a(n);
        for(int i=0;i<n;i++) cin>>a[i];
        int ans=0;
        for(int i=0;i<n-1;i++){
            if(a[i]+a[i+1]==7 || a[i]==a[i+1]) {
                ans++;
                i++;
            }
        }
        cout<<ans<<endl;
    }
    return 0;
}