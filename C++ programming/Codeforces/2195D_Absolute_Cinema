#include<bits/stdc++.h>
using namespace std;
int main(){
    int T;
    cin>>T;
    while(T--){
        int n;
        cin>>n;
        vector<long long> f(n);
        for(int i=0;i<n;i++) cin>>f[i];
        vector<long long> a(n,0);
        for(int i=1;i<n-1;i++){
            a[i]=(f[i-1]+f[i+1]-2*f[i])/2;
        }
        a[n-1]=(f[0]-(n-2)*f[n-1]+(n-1)*f[n-2])/((n-1)*2);
        long long sum=0;
        for(int i=1;i<n;i++) sum+=a[i];
        a[0]=(f[0]+f[n-1])/(n-1)-sum;
        for(int i=0;i<n;i++) cout<<a[i]<<" ";
        cout<<endl;
    }
    return 0;
}